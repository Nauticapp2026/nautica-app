# ===== Supabase =====
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Service role: SOLO server-side. Nunca exponerla al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ===== Database (Drizzle) =====
# Project Settings → Database → Connection string → URI (pooler, puerto 6543 para serverless)
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-xxx.pooler.supabase.com:6543/postgres

# Connection string directa (puerto 5432) para migraciones
DIRECT_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-xxx.pooler.supabase.com:5432/postgres

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Teléfono de soporte (botón "¿Necesitas ayuda?" del sidebar). Formato libre,
# por ejemplo +5491100000000. Si está vacío, el botón se renderiza pero no
# tiene acción al hacer click.
NEXT_PUBLIC_SOPORTE_TEL=

# ===== Pre-launch gate (temporal, hasta el lanzamiento) =====
# Muro de Basic Auth (prompt nativo del navegador) que cubre toda la web
# excepto /api/cron/*. Setear ambas para activarlo; dejar alguna vacía o
# sin setear para desactivarlo sin redeploy.
PRELAUNCH_GATE_USER=
PRELAUNCH_GATE_PASSWORD=

# ===== Emails (opcional en Fase 0, se usa desde Fase 3) =====
# RESEND_API_KEY=

# ===== Facturación — tusfacturas.app (AFIP) =====
# Credenciales desde https://www.tusfacturas.app (Configuración → API)
TUSFACTURAS_USERTOKEN=
TUSFACTURAS_APIKEY=
TUSFACTURAS_APITOKEN=
# Punto de venta configurado en AFIP (4 dígitos, ej. 00001)
TUSFACTURAS_PUNTO_VENTA=00001
# Rubro / grupo contable que aparece en los items de la factura
TUSFACTURAS_RUBRO=Servicios náuticos
TUSFACTURAS_RUBRO_GRUPO=Servicios

# Secret para validar callbacks de tusfacturas en /api/webhooks/tusfacturas.
# Generar valor random de 32+ chars (ej. `openssl rand -hex 32`). Si está vacío
# o NEXT_PUBLIC_APP_URL no es HTTPS, no se setea webhook al crear el POS.
TUSFACTURAS_WEBHOOK_SECRET=
